{
  "name": "@paiyar/monkeybars",
  "version": "0.3.1",
  "description": "Spec-to-phase workflow commands and advisory workflow hooks for agentic coding.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "license": "MIT",
  "author": {
    "name": "Pavan Aiyar",
    "email": "pavan.aiyar@gmail.com",
    "url": "https://github.com/paiyar"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paiyar/monkeybars.git"
  },
  "homepage": "https://github.com/paiyar/monkeybars#readme",
  "bugs": {
    "url": "https://github.com/paiyar/monkeybars/issues"
  },
  "keywords": [
    "agentic-coding",
    "coding-agents",
    "codex",
    "claude-code",
    "opencode",
    "workflow",
    "project-memory",
    "cli"
  ],
  "bin": {
    "monkeybars": "dist/index.js"
  },
  "files": [
    "dist",
    ".agents/plugins/marketplace.json",
    "plugins/monkeybars/README.md",
    "plugins/monkeybars/commands",
    "plugins/monkeybars/hooks",
    "plugins/monkeybars/scripts",
    "plugins/monkeybars/skills",
    "plugins/monkeybars/templates",
    "plugins/monkeybars/.codex-plugin/plugin.json"
  ],
  "scripts": {
    "build": "bun build cli/src/index.ts --target=node --format=esm --outdir=dist && bun cli/src/postbuild.ts",
    "test": "bun run build && bun test",
    "generate": "bun run build && node dist/index.js generate",
    "generate:check": "bun run build && node dist/index.js generate --check",
    "smoke:node-pack": "bun run build && node dist/index.js --help && npm pack --dry-run --cache ./.npm-cache",
    "prepare": "bun run generate"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
