{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "cli/src",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true
  },
  "include": ["cli/src/**/*.ts"]
}
